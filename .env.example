GITHUB_TOKEN=ghp_reemplace_con_token_del_repositorio

# Publicación automática de datos.
# Por seguridad, los datos y dashboard salen a una rama separada por defecto.
AWA05_GITHUB_REPO=geograficaaala/awa05-telemetria
AWA05_APP_BRANCH=main
AWA05_DATA_BRANCH=data
AWA05_DASHBOARD_BRANCH=data
AWA05_DRY_RUN=false
AWA05_CREATE_DATA_BRANCH=true

# Bloquea commits automáticos de datos a main salvo aprobación explícita.
AWA05_ALLOW_MAIN_DATA=false

# Watchdog térmico de Raspberry Pi.
AWA05_TEMP_CRITICA_C=75.0
AWA05_ENABLE_SHUTDOWN=false
AWA05_WATCHDOG_COOLDOWN_MINUTES=30
AWA05_SHUTDOWN_DELAY_SECONDS=10

# Scheduler overrides for smoke tests / controlled deployments.
# Leave empty/commented in normal operation to use config/settings.json.
# AWA05_SCHEDULER_ESPERA_RED_MINUTOS=0
# AWA05_SCHEDULER_LECTURA_INTERVALO_MINUTOS=1
# AWA05_SCHEDULER_KPI_INTERVALO_MINUTOS=1
# AWA05_SCHEDULER_WATCHDOG_INTERVALO_MINUTOS=1
